APP_NAME=Live Surveillance API
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/surveillance
WEBSOCKET_FPS=10
WEBCAM_INDEX=0
FRAME_WIDTH=960
FRAME_HEIGHT=540
MIN_JPEG_QUALITY=45
MAX_JPEG_QUALITY=85
MOTION_THRESHOLD=20.0
ENABLE_YOLO=false
YOLO_MODEL=yolov8n.pt
ALLOWED_ORIGINS=http://localhost:5173
