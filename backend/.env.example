APP_NAME=Real-Time Surveillance Backend
APP_ENV=development
LOG_LEVEL=INFO

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL – change host to container name when running in Docker
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/surveillance

# Camera
CAMERA_INDEX=0
TARGET_FPS=12

# Adaptive JPEG compression bounds
BASE_JPEG_QUALITY=75
MIN_JPEG_QUALITY=40
MAX_JPEG_QUALITY=90

# Motion detection
MOTION_THRESHOLD=0.03
MOTION_BLUR_KERNEL=21

# YOLOv8 person detection (set ENABLE_YOLO=true to activate)
ENABLE_YOLO=false
YOLO_MODEL=yolov8n.pt
PERSON_CONFIDENCE=0.4

# Events
EVENT_COOLDOWN_SECONDS=2
MAX_EVENTS=200

# Directory for event-trigger JPEG snapshots
SNAPSHOT_DIR=snapshots
